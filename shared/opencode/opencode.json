{
	"$schema": "https://opencode.ai/config.json",
	"instructions": [ "~/.config/opencode/rules/DEFAULT.md" ],
	"theme": "system",
	"enabled_providers": ["anthropic", "deepseek"],
	"model": "anthropic/claude-haiku-4-5",
	"small_model": "anthropic/claude-haiku-3",
	"permission": {
		"edit": "ask",
		"bash": "ask"
	},
	"compaction": {
		"auto": true,
		"prune": true
	},
	"watcher": {
		"ignore": ["node_modules/**", "dist/**", ".git/**"]
	},
	"mcp": {
		"tavily-remote": {
			"type": "remote",
			"url": "https://mcp.tavily.com/mcp/",
			"enabled": true,
			"headers": {
				"Authorization": "Bearer $TAVILY_API_KEY"
			}
		},
	},
}
